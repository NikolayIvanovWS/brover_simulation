          <geometry><box><size>10 0.12 0.70</size></box></geometry>
          <material><diffuse>0.58 0.58 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="west_wall">
      <static>true</static>
      <pose>-5.0 0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.12 8 0.70</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.12 8 0.70</size></box></geometry>
          <material><diffuse>0.58 0.58 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="east_wall">
      <static>true</static>
      <pose>5.0 0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.12 8 0.70</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.12 8 0.70</size></box></geometry>
          <material><diffuse>0.58 0.58 0.55 1</diffuse></material>
