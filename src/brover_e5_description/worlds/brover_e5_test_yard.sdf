    <model name="box_obstacle_1">
      <static>true</static>
      <pose>1.8 1.0 0.25 0 0 0.35</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.7 0.7 0.5</size></box></geometry>
