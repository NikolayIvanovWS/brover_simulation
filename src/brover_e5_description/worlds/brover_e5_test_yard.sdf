<?xml version="1.0"?>
<sdf version="1.9">
  <world name="brover_e5_test_yard">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.81</gravity>
    <atmosphere type="adiabatic"/>
    <scene>
      <ambient>0.32 0.32 0.32 1</ambient>
      <background>0.66 0.69 0.72 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.95 0.95 0.90 1</diffuse>
      <specular>0.12 0.12 0.12 1</specular>
      <direction>-0.45 0.25 -0.85</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>14 10</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>14 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.48 0.50 0.48 1</ambient>
            <diffuse>0.48 0.50 0.48 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="north_wall">
      <static>true</static>
      <pose>0 4.0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10 0.12 0.70</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 0.12 0.70</size></box></geometry>
          <material><diffuse>0.58 0.58 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="south_wall">
      <static>true</static>
      <pose>0 -4.0 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10 0.12 0.70</size></box></geometry>
        </collision>
