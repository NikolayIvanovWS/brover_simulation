<?xml version="1.0"?>
<sdf version="1.9">
  <world name="brover_e5_sensor_test_world">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <gravity>0 0 -9.81</gravity>
    <atmosphere type="adiabatic"/>
    <scene>
      <ambient>0.35 0.35 0.35 1</ambient>
      <background>0.68 0.71 0.74 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.95 0.95 0.90 1</diffuse>
      <specular>0.10 0.10 0.10 1</specular>
      <direction>-0.45 0.20 -0.86</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 8</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 8</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.46 0.47 0.46 1</ambient>
            <diffuse>0.46 0.47 0.46 1</diffuse>
            <specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="front_range_panel_2m">
      <static>true</static>
      <pose>2.0 0 0.45 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.08 1.6 0.9</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.08 1.6 0.9</size></box></geometry>
          <material><diffuse>0.78 0.78 0.72 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="left_range_panel">
      <static>true</static>
      <pose>0 1.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.0 0.08 0.7</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.0 0.08 0.7</size></box></geometry>
          <material><diffuse>0.35 0.46 0.65 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="right_range_panel">
      <static>true</static>
      <pose>0 -1.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.0 0.08 0.7</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.0 0.08 0.7</size></box></geometry>
          <material><diffuse>0.62 0.38 0.34 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="camera_center_target">
      <static>true</static>
      <pose>3.25 0 0.50 0 0 0</pose>
      <link name="link">
        <visual name="target_back">
          <geometry><box><size>0.05 1.4 1.0</size></box></geometry>
          <material><diffuse>0.18 0.18 0.18 1</diffuse></material>
        </visual>
        <visual name="target_white_bar">
          <pose>-0.03 0 0.18 0 0 0</pose>
          <geometry><box><size>0.06 1.25 0.12</size></box></geometry>
          <material><diffuse>0.90 0.90 0.84 1</diffuse></material>
        </visual>
        <visual name="target_blue_bar">
          <pose>-0.03 0 -0.18 0 0 0</pose>
          <geometry><box><size>0.06 1.25 0.12</size></box></geometry>
          <material><diffuse>0.20 0.38 0.74 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="round_lidar_target">
      <static>true</static>
      <pose>1.2 -2.3 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.24</radius><length>0.70</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.24</radius><length>0.70</length></cylinder></geometry>
          <material><diffuse>0.65 0.57 0.32 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="low_box_target">
      <static>true</static>
      <pose>-1.4 2.2 0.15 0 0 0.2</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.7 0.5 0.30</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.7 0.5 0.30</size></box></geometry>
          <material><diffuse>0.34 0.48 0.42 1</diffuse></material>
        </visual>
      </link>
    </model>
  </world>
</sdf>
