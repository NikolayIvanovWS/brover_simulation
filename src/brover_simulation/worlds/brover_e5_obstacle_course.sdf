      <link name="link">
        <collision name="collision"><geometry><box><size>0.22 0.22 0.70</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.22 0.22 0.70</size></box></geometry>
          <material><diffuse>0.55 0.37 0.32 1</diffuse></material>
