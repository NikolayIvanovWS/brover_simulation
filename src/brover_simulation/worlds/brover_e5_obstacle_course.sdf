    <model name="low_step">
      <static>true</static>
      <pose>1.5 -0.2 0.05 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.1 0.45 0.10</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.1 0.45 0.10</size></box></geometry>
          <material><diffuse>0.28 0.29 0.27 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="short_ramp">
