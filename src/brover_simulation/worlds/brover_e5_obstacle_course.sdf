      <link name="link">
        <collision name="collision"><geometry><box><size>1.2 0.7 0.10</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.2 0.7 0.10</size></box></geometry>
          <material><diffuse>0.42 0.43 0.38 1</diffuse></material>
