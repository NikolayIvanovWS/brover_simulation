    <model name="finish_barrier">
      <static>true</static>
      <pose>5.1 0 0.08 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.18 2.4 0.16</size></box></geometry></collision>
        <visual name="visual">
